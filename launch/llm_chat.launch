<launch>
  <arg name="api_base" default="http://127.0.0.1:1234/v1"/>
  <arg name="model" default="local-model"/>
  <arg name="temperature" default="0.2"/>
  <arg name="max_tokens" default="512"/>
  <arg name="timeout_sec" default="120.0"/>
  <arg name="system_prompt_file" default="system-prompt.md"/>
  <arg name="few_shot_file" default="few-shot-prompts.json"/>

  <node pkg="embodied_ai" type="llm_chat_node.py" name="llm_chat_node" output="screen">
    <param name="api_base" value="$(arg api_base)"/>
    <param name="model" value="$(arg model)"/>
    <param name="temperature" value="$(arg temperature)"/>
    <param name="max_tokens" value="$(arg max_tokens)"/>
    <param name="timeout_sec" value="$(arg timeout_sec)"/>
    <param name="system_prompt_file" value="$(arg system_prompt_file)"/>
    <param name="few_shot_file" value="$(arg few_shot_file)"/>
  </node>
</launch>
